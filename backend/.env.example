# AgentFlow backend environment
# Copy this file to .env and fill in your own values.
# Database: defaults to SQLite so it runs with zero infra.
# For MySQL set: mysql+pymysql://user:pass@localhost:3306/agentflow
DATABASE_URL=sqlite:///./agentflow.db

# Redis (optional). If unreachable, falls back to in-memory store.
REDIS_URL=redis://localhost:6379/0

# LLM — SiliconFlow (OpenAI-compatible API)
LLM_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Storage dir for uploaded documents / plugin packages
STORAGE_DIR=./storage

CORS_ORIGINS=http://localhost:5173
